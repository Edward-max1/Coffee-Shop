<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context=".ReceiptActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/buttonContainer">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/receiptCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="24dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:id="@+id/receiptContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:background="@color/white">

                <TextView
                    android:id="@+id/receiptHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="COFFEE SHOP"
                    android:textColor="@color/black"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/receiptSubHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="OFFICIAL RECEIPT"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="8dp">

                    <TextView
                        android:id="@+id/receiptCustomerName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:text="Customer: John Doe" />

                    <TextView
                        android:id="@+id/receiptDateTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:textSize="12sp"
                        tools:text="Date: 2024-05-16 10:00" />

                    <TextView
                        android:id="@+id/receiptPaymentMethod"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:textSize="12sp"
                        tools:text="Payment: M-Pesa" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="16dp"
                    android:background="@android:color/darker_gray" />

                <TableLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp">

                    <TableRow android:paddingVertical="8dp">
                        <TextView
                            android:layout_weight="1"
                            android:text="Item"
                            android:textStyle="bold" />
                        <TextView
                            android:gravity="center"
                            android:paddingHorizontal="8dp"
                            android:text="Qty"
                            android:textStyle="bold" />
                        <TextView
                            android:gravity="end"
                            android:text="Price"
                            android:textStyle="bold" />
                    </TableRow>

                    <TableRow
                        android:id="@+id/coffeeRow"
                        android:paddingVertical="8dp">
                        <TextView
                            android:layout_weight="1"
                            android:text="Coffee" />
                        <TextView
                            android:id="@+id/coffeeQty"
                            android:gravity="center"
                            android:text="0" />
                        <TextView
                            android:id="@+id/coffeePrice"
                            android:gravity="end"
                            android:text="KES 0" />
                    </TableRow>

                    <!-- Toppings Section -->
                    <TableRow
                        android:id="@+id/toppingsHeaderRow"
                        android:layout_marginTop="12dp"
                        android:paddingVertical="4dp"
                        android:visibility="gone">
                        <TextView
                            android:layout_weight="1"
                            android:text="TOPPINGS"
                            android:textStyle="bold"
                            android:textSize="14sp" />
                    </TableRow>

                    <TableRow
                        android:id="@+id/chapatiRow"
                        android:paddingVertical="4dp"
                        android:visibility="gone">
                        <TextView
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:text="Chapati"
                            android:textSize="13sp" />
                        <TextView
                            android:id="@+id/chapatiQty"
                            android:gravity="center"
                            android:text="1"
                            android:textSize="13sp" />
                        <TextView
                            android:id="@+id/chapatiPrice"
                            android:gravity="end"
                            android:text="KES 0"
                            android:textSize="13sp" />
                    </TableRow>

                    <TableRow
                        android:id="@+id/mandaziRow"
                        android:paddingVertical="4dp"
                        android:visibility="gone">
                        <TextView
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:text="Mandazi"
                            android:textSize="13sp" />
                        <TextView
                            android:id="@+id/mandaziQty"
                            android:gravity="center"
                            android:text="1"
                            android:textSize="13sp" />
                        <TextView
                            android:id="@+id/mandaziPrice"
                            android:gravity="end"
                            android:text="KES 0"
                            android:textSize="13sp" />
                    </TableRow>

                    <TableRow
                        android:id="@+id/githeriRow"
                        android:paddingVertical="4dp"
                        android:visibility="gone">
                        <TextView
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:text="Githeri"
                            android:textSize="13sp" />
                        <TextView
                            android:id="@+id/githeriQty"
                            android:gravity="center"
                            android:text="1"
                            android:textSize="13sp" />
                        <TextView
                            android:id="@+id/githeriPrice"
                            android:gravity="end"
                            android:text="KES 0"
                            android:textSize="13sp" />
                    </TableRow>

                    <TableRow
                        android:id="@+id/breadRow"
                        android:paddingVertical="4dp"
                        android:visibility="gone">
                        <TextView
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:text="Bread"
                            android:textSize="13sp" />
                        <TextView
                            android:id="@+id/breadQty"
                            android:gravity="center"
                            android:text="1"
                            android:textSize="13sp" />
                        <TextView
                            android:id="@+id/breadPrice"
                            android:gravity="end"
                            android:text="KES 0"
                            android:textSize="13sp" />
                    </TableRow>

                </TableLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="16dp"
                    android:background="@android:color/darker_gray" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="OVERALL TOTAL"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/overallTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="KES 0"
                        android:textColor="@android:color/holo_green_dark"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="24dp"
                    android:text="Thank you for shopping with us!"
                    android:textSize="12sp"
                    android:fontStyle="italic"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </ScrollView>

    <LinearLayout
        android:id="@+id/buttonContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/downloadBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Download Receipt"
            app:cornerRadius="8dp"
            app:icon="@android:drawable/stat_sys_download" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/backToHome"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Back to Home"
            app:cornerRadius="8dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>