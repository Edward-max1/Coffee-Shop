<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream"
    tools:context=".MainActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/logo"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/coffee1"
                    app:shapeAppearanceOverlay="@style/CircleImageView" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:text="@string/title_coffee_shop"
                    android:textColor="@color/coffee_brown"
                    android:textSize="32sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/logoutBtn"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_lock_power_off"
                    android:contentDescription="Logout"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- Customer Info Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:contentPadding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/greetingText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Good Morning"
                        android:textSize="18sp"
                        android:textColor="@color/coffee_brown"
                        android:textStyle="bold"
                        android:visibility="gone"
                        android:layout_marginBottom="8dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/nameInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:hint="@string/hint_enter_name"
                        app:startIconDrawable="@android:drawable/ic_menu_edit"
                        app:boxStrokeColor="@color/coffee_brown"
                        app:hintTextColor="@color/coffee_brown">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/nameInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPersonName"
                            android:textColor="@color/black" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Quantity Section Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:contentPadding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_number_of_coffee"
                        android:textAlignment="center"
                        android:textColor="@color/coffee_brown"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/minusBtn"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:text="@string/minus_sign"
                            android:textSize="24sp"
                            app:cornerRadius="30dp"
                            app:strokeColor="@color/coffee_brown" />

                        <EditText
                            android:id="@+id/coffeeNum"
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_marginEnd="16dp"
                            android:gravity="center"
                            android:inputType="number"
                            android:text="1"
                            android:textSize="24sp"
                            android:textColor="@color/coffee_brown"
                            android:background="@null" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/plusBtn"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:text="@string/plus_sign"
                            android:textSize="24sp"
                            app:cornerRadius="30dp"
                            app:strokeColor="@color/coffee_brown" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Toppings Section Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:contentPadding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_toppings"
                        android:textAlignment="center"
                        android:textColor="@color/coffee_brown"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <CheckBox
                                android:id="@+id/chapati"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/topping_chapati"
                                android:textColor="@color/coffee_brown" />

                            <CheckBox
                                android:id="@+id/mandazi"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/topping_mandazi"
                                android:textColor="@color/coffee_brown" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <CheckBox
                                android:id="@+id/githeri"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/topping_githeri"
                                android:textColor="@color/coffee_brown" />

                            <CheckBox
                                android:id="@+id/bread"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/topping_bread"
                                android:textColor="@color/coffee_brown" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>


            <com.google.android.material.button.MaterialButton
                android:id="@+id/order"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="@string/btn_place_order"
                android:textSize="20sp"
                app:cornerRadius="12dp"
                android:backgroundTint="@color/coffee_brown"
                android:textColor="@color/white" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>